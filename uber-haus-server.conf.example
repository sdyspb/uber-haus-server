# =============================================================================
# Configuration for Nextcloud AIO + Tailscale + nginx installer
# =============================================================================

# ---------- Required (must be filled) ----------
DOMAIN="banananas.ru"                      # your fully qualified domain name
ADMIN_PASS="nextcloud"                     # Nextcloud admin password (minimum 8 chars)

# ---------- Optional (defaults are sane) ----------
DATA_ROOT="/srv/dev-disk-by-uuid-XXXXX/appdata"   # leave empty to auto-detect

NC_PORT=8080
NGINX_HTTPS_PORT=443
OMV_HTTP_PORT=8081
OMV_HTTPS_PORT=8443
ADMIN_USER=admin

INSTALL_TAILSCALE=yes
INSTALL_NGINX=yes
INSTALL_NC_AIO=yes
RECONFIGURE_OMV=yes

# Cloudflare API token with DNS edit permission (required for automatic Let's Encrypt certificate)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# Email for Let's Encrypt notifications (optional, but recommended)
CERTBOT_EMAIL="admin@example.com"

# Full curl command to verify Cloudflare API token (optional).
# If set, the script will execute this command before obtaining the certificate.
CLOUDFLARE_VERIFY_CMD='curl "https://api.cloudflare.com/client/v4/user/tokens/verify" -H "Authorization: Bearer your-api-token"'
