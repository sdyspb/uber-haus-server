# =============================================================================
# Configuration for Nextcloud Classic + Tailscale + nginx installer
# =============================================================================

# ---------- Domain & Admin ----------
DOMAIN="banananas.ru"                     # Primary domain (landing page)
NEXTCLOUD_SUBDOMAIN="nextcloud"           # Subdomain for Nextcloud (will be nextcloud.DOMAIN)
OMV_SUBDOMAIN="omv"                       # Subdomain for OMV (will be omv.DOMAIN)
NEXTCLOUD_ADMIN_USER="admin"              # Nextcloud admin username
NEXTCLOUD_ADMIN_PASSWORD="nextcloud"      # Nextcloud admin password

# ---------- Paths ----------
DATA_ROOT=""                              # Auto-detect if empty

# ---------- Ports ----------
NC_PORT=8080                              # Internal HTTP port for Nextcloud
NGINX_HTTPS_PORT=443                      # External HTTPS port
OMV_HTTP_PORT=8081                        # New HTTP port for OMV web UI
OMV_HTTPS_PORT=8443                       # New HTTPS port for OMV web UI

# ---------- Database (MariaDB) ----------
MYSQL_DATABASE="nextcloud"
MYSQL_USER="nextcloud"
MYSQL_PASSWORD=""                         # If empty, uses NEXTCLOUD_ADMIN_PASSWORD
MYSQL_HOST="db"

# ---------- Redis ----------
REDIS_PASSWORD=""                         # If empty, uses NEXTCLOUD_ADMIN_PASSWORD

# ---------- Component selection ----------
INSTALL_TAILSCALE=yes
INSTALL_NGINX=yes
INSTALL_NC_CLASSIC=yes
RECONFIGURE_OMV=yes

# ---------- Cloudflare API ----------
CLOUDFLARE_API_TOKEN="your-token"
CERTBOT_EMAIL="admin@example.com"
CLOUDFLARE_VERIFY_CMD='curl "https://api.cloudflare.com/client/v4/user/tokens/verify" -H "Authorization: Bearer your-token"'

# ---------- Talk HPB (optional) ----------
INSTALL_TALK_HPB=yes
TALK_SECRET=""
