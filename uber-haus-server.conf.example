# =============================================================================
# Configuration for Nextcloud Classic + Tailscale + nginx installer
# =============================================================================

DOMAIN="banananas.ru"
ADMIN_PASS="nextcloud"

DATA_ROOT=""   # auto-detected

NC_PORT=8080
NGINX_HTTPS_PORT=443
OMV_HTTP_PORT=8081
OMV_HTTPS_PORT=8443
ADMIN_USER=admin

INSTALL_TAILSCALE=yes
INSTALL_NGINX=yes
INSTALL_NC_CLASSIC=yes
RECONFIGURE_OMV=yes

CLOUDFLARE_API_TOKEN="your-token"
CERTBOT_EMAIL="admin@example.com"

INSTALL_TALK_HPB=yes
TALK_SECRET=""   # auto-generated if empty
